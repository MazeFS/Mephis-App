<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Mephis.App.Views.ProfilePage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#070514">

    <Grid>
        <!-- 1. ТЯЖЕЛЫЙ БЛЮР ФОНА (Lava Lamp) -->
        <Ellipse x:Name="Blob1" WidthRequest="600" HeightRequest="600" TranslationX="-200" TranslationY="-200" HorizontalOptions="Start" VerticalOptions="Start">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#668A2BE2" Offset="0.0" />
                    <GradientStop Color="#008A2BE2" Offset="1.0" />
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>
        <Ellipse x:Name="Blob2" WidthRequest="700" HeightRequest="700" TranslationX="200" TranslationY="200" HorizontalOptions="End" VerticalOptions="Center">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#554B0082" Offset="0.0" />
                    <GradientStop Color="#004B0082" Offset="1.0" />
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>
        <Ellipse x:Name="Blob3" WidthRequest="500" HeightRequest="500" TranslationX="-100" TranslationY="200" HorizontalOptions="Start" VerticalOptions="End">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#4400BFFF" Offset="0.0" />
                    <GradientStop Color="#0000BFFF" Offset="1.0" />
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <!-- Плотная тонировка -->
        <BoxView BackgroundColor="#44070514" VerticalOptions="Fill" HorizontalOptions="Fill" />

        <!-- 2. ОСНОВНОЙ КОНТЕНТ ПРОФИЛЯ -->
        <ScrollView>
            <VerticalStackLayout Padding="20" Spacing="20" Margin="0,30,0,0">

                <!-- ЕДИНАЯ СТЕКЛЯННАЯ КАРТОЧКА ПРОФИЛЯ -->
                <Border x:Name="ProfileCard" Margin="10,0" Padding="20,25">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="40" />
                    </Border.StrokeShape>
                    <!-- Улучшенный градиент стекла с легким фиолетовым отливом -->
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#33FFFFFF" Offset="0.0" />
                            <GradientStop Color="#0AFFFFFF" Offset="0.5" />
                            <GradientStop Color="#058A2BE2" Offset="1.0" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Stroke>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#88FFFFFF" Offset="0.0" />
                            <GradientStop Color="#11FFFFFF" Offset="0.5" />
                            <GradientStop Color="#33FFFFFF" Offset="1.0" />
                        </LinearGradientBrush>
                    </Border.Stroke>
                    <Border.Shadow>
                        <Shadow Brush="#000000" Offset="0,25" Radius="35" Opacity="0.55" />
                    </Border.Shadow>

                    <Grid>
                        <!-- ================= ЛИЦЕВАЯ ЧАСТЬ (FRONT) ================= -->
                        <VerticalStackLayout x:Name="FrontView" Spacing="15">

                            <!-- Кнопка редактирования -->
                            <Grid>
                                <Button Text="✎" FontSize="20" TextColor="#B0C4DE" BackgroundColor="Transparent" 
                                        HeightRequest="40" WidthRequest="40" HorizontalOptions="End" Clicked="OnEditClicked" />
                            </Grid>

                            <!-- Аватарка со СВЕЧЕНИЕМ -->
                            <Grid HorizontalOptions="Center" WidthRequest="140" HeightRequest="140">
                                <!-- Неоновое свечение на фоне -->
                                <Ellipse WidthRequest="120" HeightRequest="120" HorizontalOptions="Center" VerticalOptions="Center">
                                    <Ellipse.Fill>
                                        <RadialGradientBrush>
                                            <GradientStop Color="#668A2BE2" Offset="0.0" />
                                            <GradientStop Color="#008A2BE2" Offset="1.0" />
                                        </RadialGradientBrush>
                                    </Ellipse.Fill>
                                </Ellipse>
                                <!-- Сама аватарка -->
                                <Border WidthRequest="120" HeightRequest="120" Stroke="#E6E6FA" StrokeThickness="2" HorizontalOptions="Center" VerticalOptions="Center">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="60" />
                                    </Border.StrokeShape>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding OpenAvatarCommand}" />
                                    </Border.GestureRecognizers>
                                    <Image Source="{Binding AvatarImage}" Aspect="AspectFill" BackgroundColor="#2A2A40"/>
                                </Border>
                            </Grid>

                            <!-- Текстовая информация -->
                            <VerticalStackLayout Spacing="5" Margin="0,-10,0,0">
                                <Label Text="{Binding Name}" FontSize="26" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center" />
                                <Label Text="{Binding Nickname}" FontSize="15" TextColor="#B0C4DE" HorizontalOptions="Center" />
                            </VerticalStackLayout>

                            <Border BackgroundColor="#15FFFFFF" Stroke="#22FFFFFF" Padding="15,6" HorizontalOptions="Center" Margin="0,5,0,0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="15"/>
                                </Border.StrokeShape>
                                <Label Text="{Binding Status}" TextColor="#E6E6FA" FontSize="14" />
                            </Border>

                            <Label Text="{Binding Bio}" TextColor="#E0E0E0" FontSize="14" HorizontalTextAlignment="Center" Margin="0,5,0,0" LineBreakMode="WordWrap"/>

                            <!-- ИЗЯЩНЫЙ РАЗДЕЛИТЕЛЬ -->
                            <BoxView HeightRequest="1" Color="#22FFFFFF" Margin="20,15" />

                            <!-- ПЛЕЕР (ТЕПЕРЬ ВНУТРИ КАРТОЧКИ!) -->
                            <Grid ColumnDefinitions="Auto, *" Margin="10,0">
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding PlayMusicCommand}" />
                                </Grid.GestureRecognizers>

                                <!-- Круглая кнопка Play -->
                                <Border Grid.Column="0" WidthRequest="46" HeightRequest="46" Stroke="#33FFFFFF" StrokeThickness="1">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="23"/>
                                    </Border.StrokeShape>
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#8E2DE2" Offset="0.0" />
                                            <GradientStop Color="#4A00E0" Offset="1.0" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Label Text="▶" FontSize="18" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center" Margin="4,0,0,0"/>
                                </Border>

                                <VerticalStackLayout Grid.Column="1" Margin="15,0,0,0" VerticalOptions="Center">
                                    <Label Text="Моя музыка" FontSize="11" TextColor="#A0A0B0" TextTransform="Uppercase" />
                                    <Label Text="{Binding CurrentMusic}" FontSize="15" FontAttributes="Bold" TextColor="White" MaxLines="1" LineBreakMode="TailTruncation" />
                                </VerticalStackLayout>
                            </Grid>

                        </VerticalStackLayout>


                        <!-- ================= ОБРАТНАЯ ЧАСТЬ (НАСТРОЙКИ) ================= -->
                        <VerticalStackLayout x:Name="BackView" Spacing="15" IsVisible="False">

                            <Grid ColumnDefinitions="*, Auto">
                                <Label Grid.Column="0" Text="Редактировать" FontSize="20" FontAttributes="Bold" TextColor="White" VerticalOptions="Center"/>
                                <Button Grid.Column="1" Text="✕" FontSize="20" TextColor="#FF6B6B" BackgroundColor="Transparent" 
                                        HeightRequest="40" WidthRequest="40" Padding="0" Clicked="OnCancelClicked" />
                            </Grid>

                            <!-- БОЛЬШОЙ АВАТАР И АККУРАТНАЯ КНОПКА ПОД НИМ -->
                            <VerticalStackLayout Spacing="10" HorizontalOptions="Center" Margin="0,5,0,10">
                                <Border WidthRequest="100" HeightRequest="100" Stroke="#8A2BE2" StrokeThickness="2" HorizontalOptions="Center">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="50" />
                                    </Border.StrokeShape>
                                    <Image Source="{Binding AvatarImage}" Aspect="AspectFill" BackgroundColor="#2A2A40"/>
                                </Border>

                                <!-- Кнопка "Пилюля" -->
                                <Button Text="Изменить фото" FontSize="12" TextColor="White" HeightRequest="32" Padding="15,0" CornerRadius="16" Command="{Binding ChangeAvatarCommand}">
                                    <Button.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#4A00E0" Offset="0.0" />
                                            <GradientStop Color="#8E2DE2" Offset="1.0" />
                                        </LinearGradientBrush>
                                    </Button.Background>
                                </Button>
                            </VerticalStackLayout>

                            <!-- Стеклянные поля ввода -->
                            <Border BackgroundColor="#1AFFFFFF" Stroke="#33FFFFFF" StrokeThickness="1" Padding="10,0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12"/>
                                </Border.StrokeShape>
                                <Entry Text="{Binding Name}" Placeholder="Имя" TextColor="White" PlaceholderColor="#88FFFFFF" BackgroundColor="Transparent" FontSize="14" />
                            </Border>

                            <Border BackgroundColor="#1AFFFFFF" Stroke="#33FFFFFF" StrokeThickness="1" Padding="10,0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12"/>
                                </Border.StrokeShape>
                                <Entry Text="{Binding Nickname}" Placeholder="Никнейм" TextColor="White" PlaceholderColor="#88FFFFFF" BackgroundColor="Transparent" FontSize="14" />
                            </Border>

                            <Border BackgroundColor="#1AFFFFFF" Stroke="#33FFFFFF" StrokeThickness="1" Padding="10,0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12"/>
                                </Border.StrokeShape>
                                <Entry Text="{Binding Status}" Placeholder="Статус" TextColor="White" PlaceholderColor="#88FFFFFF" BackgroundColor="Transparent" FontSize="14" />
                            </Border>

                            <Border BackgroundColor="#1AFFFFFF" Stroke="#33FFFFFF" StrokeThickness="1" Padding="10,0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12"/>
                                </Border.StrokeShape>
                                <Entry Text="{Binding CurrentMusic}" Placeholder="Трек (Артист - Песня)" TextColor="White" PlaceholderColor="#88FFFFFF" BackgroundColor="Transparent" FontSize="14" />
                            </Border>

                            <Border BackgroundColor="#1AFFFFFF" Stroke="#33FFFFFF" StrokeThickness="1" Padding="10,0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12"/>
                                </Border.StrokeShape>
                                <Editor Text="{Binding Bio}" Placeholder="О себе" TextColor="White" PlaceholderColor="#88FFFFFF" BackgroundColor="Transparent" HeightRequest="70" FontSize="14"/>
                            </Border>

                            <Button Text="Сохранить" TextColor="White" FontAttributes="Bold" CornerRadius="15" HeightRequest="50" Clicked="OnSaveClicked" Margin="0,10,0,0">
                                <Button.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#8A2BE2" Offset="0.0" />
                                        <GradientStop Color="#4B0082" Offset="1.0" />
                                    </LinearGradientBrush>
                                </Button.Background>
                            </Button>
                        </VerticalStackLayout>

                    </Grid>
                </Border>
            </VerticalStackLayout>
        </ScrollView>

        <!-- ОВЕРЛЕЙ ГАЛЕРЕИ (Просмотр) -->
        <Grid IsVisible="{Binding IsAvatarExpanded}" BackgroundColor="#F9000000">
            <Button Text="✕" FontSize="24" TextColor="White" BackgroundColor="Transparent" HorizontalOptions="Start" VerticalOptions="Start" Margin="20,40,0,0" Command="{Binding CloseAvatarCommand}" />
            <ScrollView VerticalOptions="Center">
                <Image Source="{Binding AvatarImage}" Aspect="AspectFit" WidthRequest="400" HeightRequest="400" />
            </ScrollView>
        </Grid>

    </Grid>
</ContentPage>